# ── قاعدة البيانات ──────────────────────────────────
DATABASE_URL=sqlite:///./sawa.db
# PostgreSQL للإنتاج:
# DATABASE_URL=postgresql://user:password@localhost/sawa_db

# ── نموذج Whisper (محلي فقط — غير مطلوب إذا تستخدم Gemini/Groq) ──
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── الأمان ───────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
# ولّد قيمة آمنة: python -c "import secrets; print(secrets.token_hex(32))"

# ── التخزين ──────────────────────────────────────────
UPLOAD_DIR=uploads

# ── حدود الخطط ──────────────────────────────────────
FREE_MAX_VIDEOS=25
FREE_MAX_DURATION_SECONDS=300
PRO_MAX_DURATION_SECONDS=3600

# ── مزودي التفريغ الصوتي ────────────────────────────
# gemini (الرئيسي) | groq | local
TRANSCRIPTION_PROVIDER=gemini

# Gemini — احصل عليه من: aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Groq — احصل عليه من: console.groq.com
GROQ_API_KEY=your_groq_api_key

# ── الذكاء الاصطناعي (Claude) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── تحديد المتحدثين (اختياري) ───────────────────────
HUGGINGFACE_TOKEN=hf_...

# ── بوابة الدفع Cryptomus ────────────────────────────
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=

# ── البريد الإلكتروني (Gmail SMTP) ────────────────────
# للاستخراج: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password_16chars
MAIL_FROM=your_gmail@gmail.com
MAIL_SERVER=smtp.gmail.com

# ── روابط التطبيق ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── البيئة ──────────────────────────────────────────
ENVIRONMENT=development

# ── إعدادات الكوكيز ────────────────────────────────
# في الإنتاج: COOKIE_SECURE=true
# في التطوير: COOKIE_SECURE=false
COOKIE_SECURE=true

# ── Cloudflare R2 (اختياري — للإنتاج) ───────────────
# إذا وُجد R2_BUCKET_NAME، يُستخدم R2 بدل القرص المحلي
# احصل على هذه المفاتيح من: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# رابط عام للصور المصغرة (اختياري — لتسريع التحميل):
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── Sentry (اختياري — لمراقبة الأخطاء) ──────────────
SENTRY_DSN=
