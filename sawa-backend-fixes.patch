+"""
+إعداد بيئة اختبار معزولة (قاعدة بيانات SQLite في الذاكرة + SECRET_KEY تجريبي).
+"""
+import os
+os.environ.setdefault("SECRET_KEY", "test_secret_key_" + "0" * 32)
+os.environ.setdefault("DATABASE_URL", "sqlite:///./_test_sawa.db")
+os.environ.setdefault("ENVIRONMENT", "development")
+
+import pytest
+from fastapi.testclient import TestClient
+from sqlalchemy import create_engine
+from sqlalchemy.orm import sessionmaker
+
+from app.main import app
+from app.database import Base, get_db
+
+# قاعدة بيانات مستقلّة للاختبارات
+TEST_DB_URL = "sqlite:///./_test_sawa.db"
+engine = create_engine(TEST_DB_URL, connect_args={"check_same_thread": False})
+TestingSessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)
+
+
+def _override_get_db():
+    db = TestingSessionLocal()
+    try:
+        yield db
+    finally:
+        db.close()
+
+
+@pytest.fixture(autouse=True)
+def _fresh_db():
+    Base.metadata.drop_all(bind=engine)
+    Base.metadata.create_all(bind=engine)
+    app.dependency_overrides[get_db] = _override_get_db
+    yield
+    app.dependency_overrides.clear()
+
+
+@pytest.fixture
+def client():
+    return TestClient(app)
