+def set_auth_cookie(response, token: str) -> None:
+    """
+    يكتب JWT كـ httpOnly cookie آمن.
+    - httponly=True : غير قابل للوصول من JavaScript (يحمي من XSS)
+    - secure : يُرسل عبر HTTPS فقط في الإنتاج
+    - samesite='lax' : يحمي من CSRF لمعظم الحالات مع دعم روابط الدخول العادية
+    """
+    is_prod = (settings.ENVIRONMENT or "development").lower() == "production"
+    response.set_cookie(
+        key=ACCESS_COOKIE_NAME,
+        value=token,
+        httponly=True,
+        secure=is_prod,
+        samesite="lax",
+        max_age=settings.ACCESS_TOKEN_EXPIRE_MINUTES * 60,
+        path="/",
+    )
+
+
+def clear_auth_cookie(response) -> None:
+    response.delete_cookie(key=ACCESS_COOKIE_NAME, path="/")
