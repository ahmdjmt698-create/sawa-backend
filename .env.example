# ── قاعدة البيانات ──────────────────────────────────
# SQLite للتطوير (لا تحتاج أي إعداد)
DATABASE_URL=sqlite:///./sawa.db

# PostgreSQL للإنتاج (علّق على السطر أعلاه وشيّل التعليق من هنا)
# DATABASE_URL=postgresql://user:password@localhost/sawa_db

# ── نموذج Whisper ────────────────────────────────────
# tiny=سريع جداً (للتطوير) | base | small | medium | large-v3 (للإنتاج)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── الأمان ───────────────────────────────────────────
# غيّر هذا لقيمة عشوائية طويلة في الإنتاج!
# يمكنك توليد واحدة: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=غير-هذا-المفتاح-في-الانتاج

# ── التخزين ──────────────────────────────────────────
UPLOAD_DIR=uploads

# ── حدود الخطط ──────────────────────────────────────
FREE_MAX_VIDEOS=25
FREE_MAX_DURATION_SECONDS=300
PRO_MAX_DURATION_SECONDS=3600

# ── الذكاء الاصطناعي ─────────────────────────────────
# احصل عليه من: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── تحديد المتحدثين (اختياري) ───────────────────────
# احصل عليه من: huggingface.co/settings/tokens
# ثم اقبل شروط النموذج في: huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_...

# ── الذكاء الاصطناعي ─────────────────────────────────
# احصل عليه من: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── تحديد المتحدثين (اختياري) ────────────────────────
# احصل عليه من: huggingface.co/settings/tokens
# ثم اقبل شروط: huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_...

# ── بوابة الدفع Cryptomus ────────────────────────────
# احصل عليهم من: cryptomus.com/cabinet/merchant
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=

# ── روابط التطبيق ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── البيئة ──────────────────────────────────────────
ENVIRONMENT=development
