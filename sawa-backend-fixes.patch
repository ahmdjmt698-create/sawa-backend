@@ -0,0 +1,131 @@
+"""
+اختبارات تلقائية لمسارات المصادقة.
+تغطّي:
+  • POST /api/auth/register (نجاح + تكرار البريد + كلمة مرور طويلة)
+  • POST /api/auth/login    (نجاح + بيانات خاطئة)
+  • تخزين JWT في httpOnly cookie (ليس متاحاً لـ JS)
+  • hashing/verification لكلمات المرور الطويلة والعربية
+"""
+import pytest
+
+from app.auth import ACCESS_COOKIE_NAME, hash_password, verify_password
+
+
+# ══════════════════════════════════════════════════════
+#  hash_password / verify_password
+# ══════════════════════════════════════════════════════
+class TestPasswordHashing:
+    def test_hash_and_verify_short(self):
+        h = hash_password("short_pw")
+        assert verify_password("short_pw", h)
+        assert not verify_password("wrong", h)
+
+    def test_long_password_200_chars(self):
+        pw = "A" * 200
+        h = hash_password(pw)
+        assert verify_password(pw, h)
+
+    def test_long_password_over_72_bytes_no_crash(self):
+        # قبل الإصلاح كان passlib يرمي استثناء عند > 72 بايت
+        pw = "كلمةمرورطويلةجداً" * 20  # عشرات البايتات (UTF-8)
+        h = hash_password(pw)
+        assert verify_password(pw, h)
+
+    def test_verify_rejects_invalid_hash(self):
+        assert not verify_password("anything", "not-a-real-hash")
+
+
+# ══════════════════════════════════════════════════════
+#  /api/auth/register
+# ══════════════════════════════════════════════════════
+class TestRegister:
+    def test_register_success_sets_cookie(self, client):
+        r = client.post(
+            "/api/auth/register",
+            json={"name": "أحمد", "email": "a@example.com", "password": "password123"},
+        )
+        assert r.status_code == 201, r.text
+        data = r.json()
+        assert data["user"]["email"] == "a@example.com"
+        assert data["user"]["name"] == "أحمد"
+        assert data["access_token"]
+        # الكوكي يجب أن يكون موجوداً — httpOnly يُتحقق منه في السلوك (لا يظهر في document.cookie)
+        assert ACCESS_COOKIE_NAME in r.cookies
+
+    def test_register_duplicate_email(self, client):
+        payload = {"name": "A", "email": "dup@example.com", "password": "password123"}
+        assert client.post("/api/auth/register", json=payload).status_code == 201
+        r = client.post("/api/auth/register", json=payload)
+        assert r.status_code == 400
+
+    def test_register_long_password_200_chars(self, client):
+        r = client.post(
+            "/api/auth/register",
+            json={"name": "B", "email": "long@example.com", "password": "x" * 200},
+        )
+        # المتوقّع: 422 (تجاوز 72 بايت) بدون أن يرمي 500
+        assert r.status_code == 422
+
+    def test_register_short_password_rejected(self, client):
+        r = client.post(
+            "/api/auth/register",
+            json={"name": "C", "email": "short@example.com", "password": "abc"},
+        )
+        assert r.status_code == 422
+
+
+# ══════════════════════════════════════════════════════
+#  /api/auth/login
+# ══════════════════════════════════════════════════════
+class TestLogin:
+    def _register(self, client, email="u@example.com", password="password123"):
+        client.post(
+            "/api/auth/register",
+            json={"name": "User", "email": email, "password": password},
+        )
+
+    def test_login_success_sets_cookie(self, client):
+        self._register(client)
+        # حذف الكوكي من عملية التسجيل لضمان اختبار مستقل
+        client.cookies.clear()
+        r = client.post(
+            "/api/auth/login",
+            data={"username": "u@example.com", "password": "password123"},
+        )
+        assert r.status_code == 200, r.text
+        assert r.json()["access_token"]
+        assert ACCESS_COOKIE_NAME in r.cookies
+
+    def test_login_wrong_password(self, client):
+        self._register(client)
+        r = client.post(
+            "/api/auth/login",
+            data={"username": "u@example.com", "password": "WRONG"},
+        )
+        assert r.status_code == 401
+
+    def test_login_unknown_email(self, client):
+        r = client.post(
+            "/api/auth/login",
+            data={"username": "nobody@example.com", "password": "password123"},
+        )
+        assert r.status_code == 401
+
+    def test_me_requires_auth(self, client):
+        client.cookies.clear()
+        assert client.get("/api/auth/me").status_code == 401
+
+    def test_me_works_via_cookie(self, client):
+        self._register(client, email="me@example.com")
+        # الكوكي محفوظ تلقائياً في جلسة TestClient
+        r = client.get("/api/auth/me")
+        assert r.status_code == 200
+        assert r.json()["email"] == "me@example.com"
+
+    def test_logout_clears_cookie(self, client):
+        self._register(client, email="out@example.com")
+        r = client.post("/api/auth/logout")
+        assert r.status_code == 200
+        # بعد الخروج: /me يجب أن يفشل
+        client.cookies.clear()
+        assert client.get("/api/auth/me").status_code == 401
